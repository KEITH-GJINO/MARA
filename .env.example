# MARA Environment Variables
# Copy to .env and add your API keys.

# LLM Providers (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Memory Backend (optional, defaults to SQLite)
# REDIS_URL=redis://localhost:6379
# POSTGRES_URL=postgresql://user:pass@localhost:5432/mara

# Notification Channels (optional)
# SLACK_WEBHOOK_URL=
